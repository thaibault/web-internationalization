<html lang="en">
    <!--region head-->
    <head>
        <meta charset="utf-8">
        <!--Prevent browser caching-->
        <meta http-equiv="cache-control" content="no-cache">
        <meta http-equiv="expires" content="0">
        <meta http-equiv="pragma" content="no-cache">
        <title>playground</title>
        <%-_.include('web-component-wrapper/polyfill.html') %>
        <!--region script-->
        <script>
            AUTO_DEFINE_WEB_INTERNATIONALIZATION = true
        </script>
        <!--endregion-->
        <style>
            lang-replacement, .wi-hide, lang-alternative:not([active]) {
                display: none;
            }
        </style>
    </head>
    <!--endregion-->
    <body>
        <web-internationalization>
            <a href="#lang-deDE">de</a>
            <br />
            <a href="#lang-enUS">en</a>
            <br />
            <a href="#lang-frFR">fr</a>

            <p>
                Your englisch version.
                <!--deDE:Ihre deutsche Variante.-->
                <!--frFR:
                    Sa version française.
                -->
            </p>

            <p>
                <lang-replace>
                    Your englisch version with <strong>dom nodes</strong>
                    inside and translations in comments.
                </lang-replace>
                <!--deDE:
                    Ihre deutsche Variante mit eingebetteten
                    <strong>dom Knoten</strong>.
                -->
                <!--frFR:
                    Votre version français <strong>dom nodes</strong> à
                    l'intérieur.
                -->
            </p>

            <p>
                <lang-replace>
                    Your englisch version with <strong>dom nodes</strong>
                    and invisible translations in special dom nodes to replace
                    content with.
                </lang-replace>
                <lang-replacement>deDE:
                    Ihre englische Version mit <strong>DOM-Knoten</strong>
                    und versteckten Übersetzungen in speziellen DOM-Knoten,
                    durch die der Inhalt ersetzt werden soll.
                </lang-replacement>
                <lang-replacement>frFR:
                    Votre version en anglais avec <strong>nœuds DOM</strong>
                    et des traductions masquées dans des nœuds DOM spécifiques
                    pour remplacer le contenu.
                </lang-replacement>
            </p>

            <p>
                <lang-alternative>
                    Your englisch version with <strong>dom nodes</strong>
                    inside and invisible translations in special but stable dom
                    nodes to make visible mutual exclusively.
                </lang-alternative>
                <lang-alternative lang="deDE">
                    Ihre englische Version mit <strong>DOM-Knoten</strong>
                    im Inneren und unsichtbaren Übersetzungen in speziellen,
                    aber stabilen DOM-Knoten, um sie gegenseitig sichtbar zu
                    machen.
                </lang-alternative>
                <lang-alternative lang="frFR">
                    Votre version anglaise avec <strong>nœuds DOM</strong>
                    à l'intérieur et des traductions invisibles dans des nœuds
                    DOM spéciaux mais stables, afin de rendre visibles
                    uniquement l'une ou l'autre.
                </lang-alternative>
            </p>

            <div>
                <!--|deDE:Ihre englische Version mit „pre replacement Syntax“.-->
                <!--|frFR:Votre version en anglais avec la « syntaxe de pré-remplacement ».-->
                <p>Your englisch version with "pre replacement syntax".</p>
            </div>

            <div>
                <!--Defines default known language area.-->
                <div class="web-internationalization-generated-content">
                    <ul>
                        <li><a href="title-1">title 1</a></li>
                        <ul>
                            <li><a href="title-2">title 2</a></li>
                        </ul>
                    </ul>
                </div>
                <h1 id="title-1">title 1<!--deDE:Titel 1--><!--frFR:titre 1--></h1>
                <h2 id="title-2">title 2<!--deDE:Titel 2--><!--frFR:titre 2--></h2>
            </div>
        </web-internationalization>
    </body>
<html>
